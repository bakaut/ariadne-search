# Copy to .env before running docker compose.
# If you change POSTGRES_* values, keep KB_POSTGRES_DSN in sync.

POSTGRES_USER=kb
POSTGRES_PASSWORD=kb
POSTGRES_DB=kb
POSTGRES_PORT=5432

KB_POSTGRES_DSN=postgresql://kb:kb@postgres:5432/kb
KB_POSTGRES_SCHEMA=kb

KB_NEO4J_PASSWORD=neo4j
KB_NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

KB_OLLAMA_PORT=11434
API_PORT=8000

KB_LOG_LEVEL=INFO
KB_SOURCE_ROOTS=/data/knowledge
KB_TEXT_EMBEDDING_MODEL=embeddinggemma
KB_SCHEDULER_INTERVAL_SECONDS=300

KB_ENABLE_EMBEDDINGS=false
KB_ENABLE_GRAPH_CONTEXT=true
KB_ENABLE_EXACT_SEARCH=true
KB_ENABLE_IMAGE_SEARCH=false
